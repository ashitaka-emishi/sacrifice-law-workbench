              "sentence_ordinal": 1,
              "text": "Parole Stirling Countersign Jersey.",
              "word_offset_start": 13,
              "word_offset_end": 17,
              "char_offset_start": 87,
              "char_offset_end": 122,
              "authorship_note": null,
