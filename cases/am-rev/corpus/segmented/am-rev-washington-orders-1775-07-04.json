          "paragraph_id": "am-rev-washington-orders-1775-07-04_s01_p01",
          "paragraph_ordinal": 1,
          "sentences": [
            {
              "sentence_id": "am-rev-washington-orders-1775-07-04_s01_p01_s01",
              "sentence_ordinal": 1,
              "text": "General Orders, 4 July 1775 General Orders",
              "word_offset_start": 0,
              "word_offset_end": 7,
              "char_offset_start": 0,
              "char_offset_end": 42,
              "authorship_note": null,
              "metaphor_instances": []
            }
          ]
        },
        {
          "paragraph_id": "am-rev-washington-orders-1775-07-04_s01_p02",
          "paragraph_ordinal": 2,
          "sentences": [
            {
              "sentence_id": "am-rev-washington-orders-1775-07-04_s01_p02_s01",
              "sentence_ordinal": 1,
              "text": "Head Quarters, Cambridge, July 4th 1775.",
              "word_offset_start": 7,
              "word_offset_end": 13,
              "char_offset_start": 44,
              "char_offset_end": 84,
              "authorship_note": null,
              "metaphor_instances": []
            }
          ]
        },
        {
          "paragraph_id": "am-rev-washington-orders-1775-07-04_s01_p03",
          "paragraph_ordinal": 3,
          "sentences": [
            {
              "sentence_id": "am-rev-washington-orders-1775-07-04_s01_p03_s01",
              "sentence_ordinal": 1,
              "text": "Parole.",
              "word_offset_start": 13,
              "word_offset_end": 14,
              "char_offset_start": 86,
              "char_offset_end": 93,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "am-rev-washington-orders-1775-07-04_s01_p03_s02",
              "sentence_ordinal": 2,
              "text": "Abington.",
              "word_offset_start": 14,
              "word_offset_end": 15,
              "char_offset_start": 94,
              "char_offset_end": 103,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "am-rev-washington-orders-1775-07-04_s01_p03_s03",
              "sentence_ordinal": 3,
              "text": "Countersign, Bedford.",
              "word_offset_start": 15,
              "word_offset_end": 17,
              "char_offset_start": 104,
              "char_offset_end": 125,
              "authorship_note": null,
              "metaphor_instances": []
            }
          ]
        },
        {
          "paragraph_id": "am-rev-washington-orders-1775-07-04_s01_p04",
          "paragraph_ordinal": 4,
          "sentences": [
            {
              "sentence_id": "am-rev-washington-orders-1775-07-04_s01_p04_s01",
              "sentence_ordinal": 1,
              "text": "Exact returns to be made by the proper Officers of all the Provisions⟨,⟩ Ordnance, Ordnance stores, Powder, Lead, working Tools of all kinds, Tents, Camp Kettles, and all other Stores under their respective care, belonging to the Armies at Roxbury and Cambridge.",
              "word_offset_start": 17,
              "word_offset_end": 59,
              "char_offset_start": 127,
              "char_offset_end": 389,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "am-rev-washington-orders-1775-07-04_s01_p04_s02",
              "sentence_ordinal": 2,
              "text": "The commanding Officer of each Regiment to make a return of the number of blankets wanted to compleat every Man with one at least.",
              "word_offset_start": 59,
              "word_offset_end": 83,
              "char_offset_start": 390,
              "char_offset_end": 520,
              "authorship_note": null,
              "metaphor_instances": []
            }
          ]
        },
        {
          "paragraph_id": "am-rev-washington-orders-1775-07-04_s01_p05",
          "paragraph_ordinal": 5,
          "sentences": [
            {
              "sentence_id": "am-rev-washington-orders-1775-07-04_s01_p05_s01",
              "sentence_ordinal": 1,
              "text": "The Hon: Artemus Ward, Charles Lee, Philip Schuyler, and Israel Putnam Esquires, are appointed Major Generals of the American Army and due Obedience is to be paid them as such.",
              "word_offset_start": 83,
              "word_offset_end": 113,
              "char_offset_start": 522,
              "char_offset_end": 698,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "am-rev-washington-orders-1775-07-04_s01_p05_s02",
              "sentence_ordinal": 2,
              "text": "The Continental Congress not having compleated the appointments of the other officers in said army, nor had sufficient time to prepare and forward their Commissions; every Officer is to continue to do duty in the Rank and Station he at present holds untill further orders.",
              "word_offset_start": 113,
              "word_offset_end": 158,
              "char_offset_start": 699,
              "char_offset_end": 971,
              "authorship_note": null,
              "metaphor_instances": []
            }
          ]
        },
        {
          "paragraph_id": "am-rev-washington-orders-1775-07-04_s01_p06",
          "paragraph_ordinal": 6,
          "sentences": [
            {
              "sentence_id": "am-rev-washington-orders-1775-07-04_s01_p06_s01",
              "sentence_ordinal": 1,
              "text": "Thomas Mifflin Esqr. is appointed by the General one of his Aid-de-Camps.",
              "word_offset_start": 158,
              "word_offset_end": 170,
              "char_offset_start": 973,
              "char_offset_end": 1046,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "am-rev-washington-orders-1775-07-04_s01_p06_s02",
              "sentence_ordinal": 2,
              "text": "Joseph Reed Esqr. is in like manner appointed Secretary to the General, and they are in future to be consider'd and regarded as such.",
              "word_offset_start": 170,
              "word_offset_end": 194,
              "char_offset_start": 1047,
              "char_offset_end": 1180,
              "authorship_note": null,
              "metaphor_instances": []
            }
          ]
        },
        {
          "paragraph_id": "am-rev-washington-orders-1775-07-04_s01_p07",
          "paragraph_ordinal": 7,
          "sentences": [
            {
              "sentence_id": "am-rev-washington-orders-1775-07-04_s01_p07_s01",
              "sentence_ordinal": 1,
              "text": "The Continental Congress having now taken all the Troops of the several Colonies, which have been raised, or which may be hereafter raised, for the support and defence of the Liberties of America; into their Pay and Service: They are now the Troops of the United Provinces of North America; and it is hoped that all Distinctions of Colonies will be laid aside; so that one and the same spirit may animate the whole, and the only Contest be, who shall render, on this great and trying occasion, the most essential service to the great and common cause in which we are all engaged.",
              "word_offset_start": 194,
              "word_offset_end": 298,
              "char_offset_start": 1182,
              "char_offset_end": 1761,
              "authorship_note": null,
              "metaphor_instances": []
            }
          ]
        },
        {
          "paragraph_id": "am-rev-washington-orders-1775-07-04_s01_p08",
          "paragraph_ordinal": 8,
          "sentences": [
            {
              "sentence_id": "am-rev-washington-orders-1775-07-04_s01_p08_s01",
              "sentence_ordinal": 1,
              "text": "It is required and expected that exact discipline be observed, and due Subordination prevail thro' the whole Army, as a Failure in these most essential points must necessarily produce extreme Hazard, Disorder and Confusion; and end in shameful disappointment and disgrace.",
              "word_offset_start": 298,
              "word_offset_end": 339,
              "char_offset_start": 1763,
              "char_offset_end": 2035,
              "authorship_note": null,
              "metaphor_instances": []
            }
          ]
        },
        {
          "paragraph_id": "am-rev-washington-orders-1775-07-04_s01_p09",
          "paragraph_ordinal": 9,
          "sentences": [
            {
              "sentence_id": "am-rev-washington-orders-1775-07-04_s01_p09_s01",
              "sentence_ordinal": 1,
              "text": "The General most earnestly requires, and expects, a due observance of those articles of war, established for the Government of the army, which forbid profane cursing, swearing & drunkeness; And in like manner requires & expects, of all Officers, and Soldiers, not engaged on actual duty, a punctual attendance on divine service, to implore the blessings of heaven upon the means used for our safety and defence.",
              "word_offset_start": 339,
              "word_offset_end": 406,
              "char_offset_start": 2037,
              "char_offset_end": 2448,
              "authorship_note": null,
              "metaphor_instances": []
            }
          ]
        },
        {
          "paragraph_id": "am-rev-washington-orders-1775-07-04_s01_p10",
          "paragraph_ordinal": 10,
          "sentences": [
            {
              "sentence_id": "am-rev-washington-orders-1775-07-04_s01_p10_s01",
              "sentence_ordinal": 1,
              "text": "All Officers are required and expected to pay diligent Attention, to keep their Men neat and clean—to visit them often at their quarters, and inculcate upon them the necessity of cleanliness, as essential to their health and service.",
              "word_offset_start": 406,
              "word_offset_end": 444,
              "char_offset_start": 2450,
              "char_offset_end": 2683,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "am-rev-washington-orders-1775-07-04_s01_p10_s02",
              "sentence_ordinal": 2,
              "text": "They are particularly to see, that they have Straw to lay on, if to be had, and to make it known if they are destitute of this article.",
              "word_offset_start": 444,
              "word_offset_end": 472,
              "char_offset_start": 2684,
              "char_offset_end": 2819,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "am-rev-washington-orders-1775-07-04_s01_p10_s03",
              "sentence_ordinal": 3,
              "text": "They are also to take care that Necessarys be provided in the Camps and frequently filled up to prevent their being offensive and unhealthy.",
              "word_offset_start": 472,
              "word_offset_end": 496,
              "char_offset_start": 2820,
              "char_offset_end": 2960,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "am-rev-washington-orders-1775-07-04_s01_p10_s04",
              "sentence_ordinal": 4,
              "text": "Proper Notice will be taken of such Officers and Men, as distinguish themselves by their attention to these necessary duties.",
              "word_offset_start": 496,
              "word_offset_end": 516,
              "char_offset_start": 2961,
              "char_offset_end": 3086,
              "authorship_note": null,
              "metaphor_instances": []
            }
          ]
        },
        {
          "paragraph_id": "am-rev-washington-orders-1775-07-04_s01_p11",
          "paragraph_ordinal": 11,
          "sentences": [
            {
              "sentence_id": "am-rev-washington-orders-1775-07-04_s01_p11_s01",
              "sentence_ordinal": 1,
              "text": "The commanding Officer of each Regiment is to take particular care that not more than two Men of a Company be absent on furlough at the same time, unless in very extraordinary cases.",
              "word_offset_start": 516,
              "word_offset_end": 549,
              "char_offset_start": 3088,
              "char_offset_end": 3270,
              "authorship_note": null,
              "metaphor_instances": []
            }
          ]
        },
        {
          "paragraph_id": "am-rev-washington-orders-1775-07-04_s01_p12",
          "paragraph_ordinal": 12,
          "sentences": [
            {
              "sentence_id": "am-rev-washington-orders-1775-07-04_s01_p12_s01",
              "sentence_ordinal": 1,
              "text": "Col. Gardner is to be buried to morrow at 3, OClock, P: M. with the military Honors due to so brave and gallant an Officer, who fought, bled and died in the Cause of his country and mankind.",
              "word_offset_start": 549,
              "word_offset_end": 587,
              "char_offset_start": 3272,
              "char_offset_end": 3462,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "am-rev-washington-orders-1775-07-04_s01_p12_s02",
              "sentence_ordinal": 2,
              "text": "His own Regiment, except the company at Malden, to attend on this mournful occasion.",
              "word_offset_start": 587,
              "word_offset_end": 601,
              "char_offset_start": 3463,
              "char_offset_end": 3547,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "am-rev-washington-orders-1775-07-04_s01_p12_s03",
              "sentence_ordinal": 3,
              "text": "The places of those Companies in the Lines on Prospect Hill, to be supplied by Col. Glovers regiment 'till the funeral is over.",
              "word_offset_start": 601,
              "word_offset_end": 624,
              "char_offset_start": 3548,
              "char_offset_end": 3675,
              "authorship_note": null,
              "metaphor_instances": []
            }
          ]
        },
        {
          "paragraph_id": "am-rev-washington-orders-1775-07-04_s01_p13",
          "paragraph_ordinal": 13,
          "sentences": [
            {
              "sentence_id": "am-rev-washington-orders-1775-07-04_s01_p13_s01",
              "sentence_ordinal": 1,
              "text": "No Person is to be allowed to go to Fresh-water pond a fishing or on any other occasion as there may be danger of introducing the small pox into the army.",
              "word_offset_start": 624,
              "word_offset_end": 655,
              "char_offset_start": 3677,
              "char_offset_end": 3831,
              "authorship_note": null,
              "metaphor_instances": []
            }
          ]
        },
        {
          "paragraph_id": "am-rev-washington-orders-1775-07-04_s01_p14",
          "paragraph_ordinal": 14,
          "sentences": [
            {
              "sentence_id": "am-rev-washington-orders-1775-07-04_s01_p14_s01",
              "sentence_ordinal": 1,
              "text": "It is strictly required and commanded that there be no firing of Cannon or small Arms from any of the Lines, or elsewhere, except in case of necessary, immediate defence, or special order given for that purpose.",
              "word_offset_start": 655,
              "word_offset_end": 692,
              "char_offset_start": 3833,
              "char_offset_end": 4044,
              "authorship_note": null,
              "metaphor_instances": []
            }
          ]
        },
        {
          "paragraph_id": "am-rev-washington-orders-1775-07-04_s01_p15",
          "paragraph_ordinal": 15,
          "sentences": [
            {
              "sentence_id": "am-rev-washington-orders-1775-07-04_s01_p15_s01",
              "sentence_ordinal": 1,
              "text": "All Prisoners taken, Deserters coming in, Persons coming out of Boston, who can give any Intelligence; any Captures of any kind from the Enemy, are to be immediately reported and brought up to Head Quarters in Cambridge.",
              "word_offset_start": 692,
              "word_offset_end": 729,
              "char_offset_start": 4046,
              "char_offset_end": 4266,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "am-rev-washington-orders-1775-07-04_s01_p15_s02",
              "sentence_ordinal": 2,
              "text": "Capt. Griffin is appointed Aid-de-Camp to General Lee and to be regarded as such.",
              "word_offset_start": 729,
              "word_offset_end": 743,
              "char_offset_start": 4267,
              "char_offset_end": 4348,
              "authorship_note": null,
              "metaphor_instances": []
            }
          ]
        },
        {
          "paragraph_id": "am-rev-washington-orders-1775-07-04_s01_p16",
          "paragraph_ordinal": 16,
          "sentences": [
            {
              "sentence_id": "am-rev-washington-orders-1775-07-04_s01_p16_s01",
              "sentence_ordinal": 1,
              "text": "The Guard for the security of the stores at Watertown, is to be increased to thirty men immediately.",
              "word_offset_start": 743,
              "word_offset_end": 761,
              "char_offset_start": 4350,
              "char_offset_end": 4450,
              "authorship_note": null,
              "metaphor_instances": []
            }
          ]
        },
        {
          "paragraph_id": "am-rev-washington-orders-1775-07-04_s01_p17",
          "paragraph_ordinal": 17,
          "sentences": [
            {
              "sentence_id": "am-rev-washington-orders-1775-07-04_s01_p17_s01",
              "sentence_ordinal": 1,
              "text": "A serjeant and six men to be set as a Guard to the Hospital, and are to apply to Doctor Rand.",
              "word_offset_start": 761,
              "word_offset_end": 782,
              "char_offset_start": 4452,
              "char_offset_end": 4545,
              "authorship_note": null,
              "metaphor_instances": []
            }
          ]
        },
        {
          "paragraph_id": "am-rev-washington-orders-1775-07-04_s01_p18",
          "paragraph_ordinal": 18,
          "sentences": [
            {
              "sentence_id": "am-rev-washington-orders-1775-07-04_s01_p18_s01",
              "sentence_ordinal": 1,
              "text": "Complaint having been made against John White Quarter Master of Col. Nixon's Regmt for misdemeanors in drawing out Provisions for more Men than the Regiment consisted of; A Court Martial consisting of one Captain and four Subalterns is ordered to be held on said White, who are to enquire, determine and report.",
              "word_offset_start": 782,
              "word_offset_end": 834,
              "char_offset_start": 4547,
              "char_offset_end": 4858,
              "authorship_note": null,
              "metaphor_instances": []
            }
          ]
        },
        {
          "paragraph_id": "am-rev-washington-orders-1775-07-04_s01_p19",
          "paragraph_ordinal": 19,
          "sentences": [
            {
              "sentence_id": "am-rev-washington-orders-1775-07-04_s01_p19_s01",
              "sentence_ordinal": 1,
              "text": "After Orders.",
              "word_offset_start": 834,
              "word_offset_end": 836,
              "char_offset_start": 4860,
              "char_offset_end": 4873,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "am-rev-washington-orders-1775-07-04_s01_p19_s02",
              "sentence_ordinal": 2,
              "text": "10 OClock",
              "word_offset_start": 836,
              "word_offset_end": 838,
              "char_offset_start": 4874,
              "char_offset_end": 4883,
              "authorship_note": null,
              "metaphor_instances": []
            }
          ]
        },
        {
          "paragraph_id": "am-rev-washington-orders-1775-07-04_s01_p20",
          "paragraph_ordinal": 20,
          "sentences": [
            {
              "sentence_id": "am-rev-washington-orders-1775-07-04_s01_p20_s01",
              "sentence_ordinal": 1,
              "text": "The General desires that some Carpenters be immediately set to work at Brattle's Stables, to fix up Stalls for eight Horses, and more if the Room will admit, with suitable racks, mangers &c.",
              "word_offset_start": 838,
              "word_offset_end": 871,
              "char_offset_start": 4885,
              "char_offset_end": 5075,
              "authorship_note": null,
              "metaphor_instances": []
            }
          ]
        }
      ]
    }
  ],
