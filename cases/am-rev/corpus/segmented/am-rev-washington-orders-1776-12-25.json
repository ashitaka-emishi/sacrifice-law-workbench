        {
          "paragraph_id": "am-rev-washington-orders-1776-12-25_s01_p23",
          "paragraph_ordinal": 23,
          "sentences": [
            {
              "sentence_id": "am-rev-washington-orders-1776-12-25_s01_p23_s01",
              "sentence_ordinal": 1,
              "text": "1.",
              "word_offset_start": 328,
              "word_offset_end": 329,
              "char_offset_start": 1957,
