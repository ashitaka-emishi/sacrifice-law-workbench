              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "am-rev-washington-orders-1776-12-25_s01_p23_s02",
              "sentence_ordinal": 2,
              "text": "On 26 Dec. 1777 William Livingston wrote GW enclosing a copy of his letter to Henry Laurens of the previous day.",
              "word_offset_start": 329,
              "word_offset_end": 350,
              "char_offset_start": 1960,
              "char_offset_end": 2072,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "am-rev-washington-orders-1776-12-25_s01_p23_s03",
              "sentence_ordinal": 3,
              "text": "Livingston’s letter to Laurens, detailing the abuses and deficiencies in the hospital system, was based in large part on information provided by Rush.",
              "word_offset_start": 350,
              "word_offset_end": 373,
              "char_offset_start": 2073,
              "char_offset_end": 2223,
              "authorship_note": null,
              "metaphor_instances": []
            }
