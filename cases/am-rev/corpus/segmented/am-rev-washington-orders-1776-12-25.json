              "sentence_id": "am-rev-washington-orders-1776-12-25_s01_p22_s01",
              "sentence_ordinal": 1,
              "text": "LS, in Tench Tilghman’s writing, NcD-MC: Benjamin Rush Papers; Df, DLC:GW; Varick transcript, DLC:GW.",
              "word_offset_start": 314,
