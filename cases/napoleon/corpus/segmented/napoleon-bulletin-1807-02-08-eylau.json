    {
      "section_id": "napoleon-bulletin-1807-02-08-eylau_s01",
      "section_label": "body",
      "section_ordinal": 1,
      "paragraphs": [
        {
          "paragraph_id": "napoleon-bulletin-1807-02-08-eylau_s01_p01",
          "paragraph_ordinal": 1,
          "sentences": [
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p01_s01",
              "sentence_ordinal": 1,
              "text": "11796. — 58e BULLETIN DE LA GRANDE ARMÉE.",
              "word_offset_start": 0,
              "word_offset_end": 8,
              "char_offset_start": 0,
              "char_offset_end": 41,
              "authorship_note": null,
              "metaphor_instances": []
            }
          ]
        },
        {
          "paragraph_id": "napoleon-bulletin-1807-02-08-eylau_s01_p02",
          "paragraph_ordinal": 2,
          "sentences": [
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p02_s01",
              "sentence_ordinal": 1,
              "text": "Preussich-Eylau, 9 février 1807.",
              "word_offset_start": 8,
              "word_offset_end": 12,
              "char_offset_start": 43,
              "char_offset_end": 75,
              "authorship_note": null,
              "metaphor_instances": []
            }
          ]
        },
        {
          "paragraph_id": "napoleon-bulletin-1807-02-08-eylau_s01_p03",
          "paragraph_ordinal": 3,
          "sentences": [
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p03_s01",
              "sentence_ordinal": 1,
              "text": "COMBAT D'EYLAU.",
              "word_offset_start": 12,
              "word_offset_end": 14,
              "char_offset_start": 77,
              "char_offset_end": 92,
              "authorship_note": null,
              "metaphor_instances": []
            }
          ]
        },
        {
          "paragraph_id": "napoleon-bulletin-1807-02-08-eylau_s01_p04",
          "paragraph_ordinal": 4,
          "sentences": [
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p04_s01",
              "sentence_ordinal": 1,
              "text": "A un quart de lieue de la petite ville de Preussich-Eylau est un plateau qui défend le débouché de la plaine.",
              "word_offset_start": 14,
              "word_offset_end": 35,
              "char_offset_start": 94,
              "char_offset_end": 203,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p04_s02",
              "sentence_ordinal": 2,
              "text": "Le maréchal Soult ordonna au 46e et au 18e régiment de ligne de l'enlever.",
              "word_offset_start": 35,
              "word_offset_end": 49,
              "char_offset_start": 204,
              "char_offset_end": 278,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p04_s03",
              "sentence_ordinal": 3,
              "text": "Trois régiments qui le défendaient furent culbutés.",
              "word_offset_start": 49,
              "word_offset_end": 56,
              "char_offset_start": 279,
              "char_offset_end": 330,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p04_s04",
              "sentence_ordinal": 4,
              "text": "Mais au même moment, une colonne de cavalerie russe chargea l'extrémité de la gauche du 18% et mit en désordre un de ses bataillons ; les dragons de la division Klein s'en aperçurent à temps.",
              "word_offset_start": 56,
              "word_offset_end": 91,
              "char_offset_start": 331,
              "char_offset_end": 522,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p04_s05",
              "sentence_ordinal": 5,
              "text": "Les troupes s'engagèrent dans la ville d'Eylau.",
              "word_offset_start": 91,
              "word_offset_end": 98,
              "char_offset_start": 523,
              "char_offset_end": 570,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p04_s06",
              "sentence_ordinal": 6,
              "text": "L'ennemi avait placé dans une église et un cimetière plusieurs régiments.",
              "word_offset_start": 98,
              "word_offset_end": 109,
              "char_offset_start": 571,
              "char_offset_end": 644,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p04_s07",
              "sentence_ordinal": 7,
              "text": "Il fit là une opiniàtre résistance; et, après un combat meurtrier de part et d'autre, la position fut enlevée à dix heures du soir.",
              "word_offset_start": 109,
              "word_offset_end": 133,
              "char_offset_start": 645,
              "char_offset_end": 776,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p04_s08",
              "sentence_ordinal": 8,
              "text": "La division Legrand prit ses bivouacs au-devant de la ville, et la division Saint-Hilaire à la droite.",
              "word_offset_start": 133,
              "word_offset_end": 150,
              "char_offset_start": 777,
              "char_offset_end": 879,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p04_s09",
              "sentence_ordinal": 9,
              "text": "Le corps du maréchal Augcreau se plaça sur la gauche.",
              "word_offset_start": 150,
              "word_offset_end": 160,
              "char_offset_start": 880,
              "char_offset_end": 933,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p04_s10",
              "sentence_ordinal": 10,
              "text": "Le corps. du maréchal Davout avait, dès la veille, marché pour déborder Eylau et tomber sur le flanc gauche de l'ennemi, s'il ne changeait pas de position.",
              "word_offset_start": 160,
              "word_offset_end": 187,
              "char_offset_start": 934,
              "char_offset_end": 1089,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p04_s11",
              "sentence_ordinal": 11,
              "text": "Le maréchal Ney était en marche pour le déborder sur son flanc droit.",
              "word_offset_start": 187,
              "word_offset_end": 200,
              "char_offset_start": 1090,
              "char_offset_end": 1159,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p04_s12",
              "sentence_ordinal": 12,
              "text": "C'est dans cette position que la nuit se passa.",
              "word_offset_start": 200,
              "word_offset_end": 209,
              "char_offset_start": 1160,
              "char_offset_end": 1207,
              "authorship_note": null,
              "metaphor_instances": []
            }
          ]
        },
        {
          "paragraph_id": "napoleon-bulletin-1807-02-08-eylau_s01_p05",
          "paragraph_ordinal": 5,
          "sentences": [
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p05_s01",
              "sentence_ordinal": 1,
              "text": "BATAILLE D'EYLAU.",
              "word_offset_start": 209,
              "word_offset_end": 211,
              "char_offset_start": 1209,
              "char_offset_end": 1226,
              "authorship_note": null,
              "metaphor_instances": []
            }
          ]
        },
        {
          "paragraph_id": "napoleon-bulletin-1807-02-08-eylau_s01_p06",
          "paragraph_ordinal": 6,
          "sentences": [
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p06_s01",
              "sentence_ordinal": 1,
              "text": "A la pointe du jour, l'ennemi commença l'attaque par une vive canonnade sur la ville d'Eylau et sur la division Saint-Hilaire.",
              "word_offset_start": 211,
              "word_offset_end": 232,
              "char_offset_start": 1228,
              "char_offset_end": 1354,
              "authorship_note": null,
              "metaphor_instances": []
            }
          ]
        },
        {
          "paragraph_id": "napoleon-bulletin-1807-02-08-eylau_s01_p07",
          "paragraph_ordinal": 7,
          "sentences": [
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p07_s01",
              "sentence_ordinal": 1,
              "text": "L'Empereur se porta à la position de l'église que l'ennemi avait tant défendue la veille.",
              "word_offset_start": 232,
              "word_offset_end": 247,
              "char_offset_start": 1356,
              "char_offset_end": 1445,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p07_s02",
              "sentence_ordinal": 2,
              "text": "Il fit avancer le corps du maréchal Augereau, et fit canonner le monticule par quarante pièces d'artillerie de sa Garde.",
              "word_offset_start": 247,
              "word_offset_end": 267,
              "char_offset_start": 1446,
              "char_offset_end": 1566,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p07_s03",
              "sentence_ordinal": 3,
              "text": "Une épouvantable canonnade s'engagea de part et d'autre.",
              "word_offset_start": 267,
              "word_offset_end": 275,
              "char_offset_start": 1567,
              "char_offset_end": 1623,
              "authorship_note": null,
              "metaphor_instances": []
            }
          ]
        },
        {
          "paragraph_id": "napoleon-bulletin-1807-02-08-eylau_s01_p08",
          "paragraph_ordinal": 8,
          "sentences": [
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p08_s01",
              "sentence_ordinal": 1,
              "text": "L'armée russe, rangée en colonnes, était à demi-portée de canon : tout coup frappait.",
              "word_offset_start": 275,
              "word_offset_end": 289,
              "char_offset_start": 1625,
              "char_offset_end": 1710,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p08_s02",
              "sentence_ordinal": 2,
              "text": "Il parut un moment, aux mouvements de l'ennemi, qu'impatienté de tant souffrir il voulait déborder notre gauche.",
              "word_offset_start": 289,
              "word_offset_end": 306,
              "char_offset_start": 1711,
              "char_offset_end": 1823,
              "authorship_note": null,
              "metaphor_instances": []
            }
          ]
        },
        {
          "paragraph_id": "napoleon-bulletin-1807-02-08-eylau_s01_p09",
          "paragraph_ordinal": 9,
          "sentences": [
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p09_s01",
              "sentence_ordinal": 1,
              "text": "Au même moment, les tirailleurs du maréchal Davout se firent entendre et arrivèrent sur les derrières de l'armée ennemie.",
              "word_offset_start": 306,
              "word_offset_end": 325,
              "char_offset_start": 1825,
              "char_offset_end": 1946,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p09_s02",
              "sentence_ordinal": 2,
              "text": "Le corps du maréchal Augereau déboucha en même temps en colonnes, pour se porter sur le centre de l'ennemi, et, partageant ainsi son attention, l'empêcher de se porter tout entier contre le corps du maréchal Davout; la division Saint-Hilaire déboucha sur la droite, l'un et l'autre devant manœuvrer pour se réunir au maréchal Davout.",
              "word_offset_start": 325,
              "word_offset_end": 379,
              "char_offset_start": 1947,
              "char_offset_end": 2280,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p09_s03",
              "sentence_ordinal": 3,
              "text": "A peine le corps du maréchal Augereau et la division Saint-Hilaire eurent-ils débouché, qu'une neige épaisse, et telle qu'on ne distinguait pas à deux pas, couvrit les deux armées.",
              "word_offset_start": 379,
              "word_offset_end": 408,
              "char_offset_start": 2281,
              "char_offset_end": 2461,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p09_s04",
              "sentence_ordinal": 4,
              "text": "Dans cette obscurité, le",
              "word_offset_start": 408,
              "word_offset_end": 412,
              "char_offset_start": 2462,
              "char_offset_end": 2486,
              "authorship_note": null,
              "metaphor_instances": []
            }
          ]
        },
        {
          "paragraph_id": "napoleon-bulletin-1807-02-08-eylau_s01_p10",
          "paragraph_ordinal": 10,
          "sentences": [
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p10_s01",
              "sentence_ordinal": 1,
              "text": "point de direction fut perdu, et les colonnes, s'appuyant trop à gauche, flottèrent incertaines.",
              "word_offset_start": 412,
              "word_offset_end": 426,
              "char_offset_start": 2488,
              "char_offset_end": 2584,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p10_s02",
              "sentence_ordinal": 2,
              "text": "Cette désolante obscurité dura une demi-heure.",
              "word_offset_start": 426,
              "word_offset_end": 432,
              "char_offset_start": 2585,
              "char_offset_end": 2631,
              "authorship_note": null,
              "metaphor_instances": []
            }
          ]
        },
        {
          "paragraph_id": "napoleon-bulletin-1807-02-08-eylau_s01_p11",
          "paragraph_ordinal": 11,
          "sentences": [
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p11_s01",
              "sentence_ordinal": 1,
              "text": "Le temps s'étant éclairci, le grand-duc de Berg à la tète de la cavalerie, et soutenu par le maréchal Bessières à la tête de la Garde, tourna la division Saint-Hilaire et tomba sur l'armée ennemie; manœuvre audacieuse s'il en fut jamais, qui couvrit de gloire la cavalerie, et qui était devenue nécessaire dans la circonstance où se trouvaient nos colonnes.",
              "word_offset_start": 432,
              "word_offset_end": 492,
              "char_offset_start": 2633,
              "char_offset_end": 2990,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p11_s02",
              "sentence_ordinal": 2,
              "text": "La cavalerie ennemie, qui voulut s'opposer à cette manœuvre, fut culbutée; le massacre fut horrible.",
              "word_offset_start": 492,
              "word_offset_end": 507,
              "char_offset_start": 2991,
              "char_offset_end": 3091,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p11_s03",
              "sentence_ordinal": 3,
              "text": "Deux lignes d'infanterie russe furent rompues; la troisième ne résista qu'en s'adossant à un bois.",
              "word_offset_start": 507,
              "word_offset_end": 522,
              "char_offset_start": 3092,
              "char_offset_end": 3190,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p11_s04",
              "sentence_ordinal": 4,
              "text": "Des escadrons de la Garde traversèrent deux fois toute l'armée ennemie.",
              "word_offset_start": 522,
              "word_offset_end": 533,
              "char_offset_start": 3191,
              "char_offset_end": 3262,
              "authorship_note": null,
              "metaphor_instances": []
            }
          ]
        },
        {
          "paragraph_id": "napoleon-bulletin-1807-02-08-eylau_s01_p12",
          "paragraph_ordinal": 12,
          "sentences": [
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p12_s01",
              "sentence_ordinal": 1,
              "text": "Cette charge brillante et inouïe, qui avait culbuté plus de 20,000 hommes d'infanterie et les avait obligés à abandonner leurs pièces, aurait décidé sur-le-champ la victoire, sans le bois et quelques difficultés de terrain.",
              "word_offset_start": 533,
              "word_offset_end": 567,
              "char_offset_start": 3264,
              "char_offset_end": 3487,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p12_s02",
              "sentence_ordinal": 2,
              "text": "Le général de division d'Hautpoul fut blessé d'un biscaïen.",
              "word_offset_start": 567,
              "word_offset_end": 576,
              "char_offset_start": 3488,
              "char_offset_end": 3547,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p12_s03",
              "sentence_ordinal": 3,
              "text": "Le général Dahlmann, commandant les chasseurs de la Garde, et un bon nombre de ses intrépides soldats, moururent avec gloire.",
              "word_offset_start": 576,
              "word_offset_end": 596,
              "char_offset_start": 3548,
              "char_offset_end": 3673,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p12_s04",
              "sentence_ordinal": 4,
              "text": "Mais les 100 dragons, cuirassiers ou soldats de la Garde que l'on trouva sur le champ de bataille, on les y trouva environnés de plus de 1,000 cadavres ennemis.",
              "word_offset_start": 596,
              "word_offset_end": 625,
              "char_offset_start": 3674,
              "char_offset_end": 3834,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p12_s05",
              "sentence_ordinal": 5,
              "text": "Cette partie du champ de bataille fait horreur à voir.",
              "word_offset_start": 625,
              "word_offset_end": 635,
              "char_offset_start": 3835,
              "char_offset_end": 3889,
              "authorship_note": null,
              "metaphor_instances": []
            }
          ]
        },
        {
          "paragraph_id": "napoleon-bulletin-1807-02-08-eylau_s01_p13",
          "paragraph_ordinal": 13,
          "sentences": [
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p13_s01",
              "sentence_ordinal": 1,
              "text": "Pendant ce temps, le corps du maréchal Davout débouchait derrière l'ennemi.",
              "word_offset_start": 635,
              "word_offset_end": 646,
              "char_offset_start": 3891,
              "char_offset_end": 3966,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p13_s02",
              "sentence_ordinal": 2,
              "text": "La neige, qui, plusieurs fois dans la journée,",
              "word_offset_start": 646,
              "word_offset_end": 654,
              "char_offset_start": 3967,
              "char_offset_end": 4013,
              "authorship_note": null,
              "metaphor_instances": []
            }
          ]
        },
        {
          "paragraph_id": "napoleon-bulletin-1807-02-08-eylau_s01_p14",
          "paragraph_ordinal": 14,
          "sentences": [
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p14_s01",
              "sentence_ordinal": 1,
              "text": "obscurcit le temps, retarda aussi sa marche et l'ensemble de ses colonnes.",
              "word_offset_start": 654,
              "word_offset_end": 666,
              "char_offset_start": 4015,
              "char_offset_end": 4089,
              "authorship_note": null,
              "metaphor_instances": []
            }
          ]
        },
        {
          "paragraph_id": "napoleon-bulletin-1807-02-08-eylau_s01_p15",
          "paragraph_ordinal": 15,
          "sentences": [
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p15_s01",
              "sentence_ordinal": 1,
              "text": "Le mal de l'ennemi est immense; celui que nous avons éprouvé est considérable.",
              "word_offset_start": 666,
              "word_offset_end": 679,
              "char_offset_start": 4091,
              "char_offset_end": 4169,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p15_s02",
              "sentence_ordinal": 2,
              "text": "Trois cents bouches à feu ont produit la mort de part et d'autre pendant douze heures.",
              "word_offset_start": 679,
              "word_offset_end": 695,
              "char_offset_start": 4170,
              "char_offset_end": 4256,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p15_s03",
              "sentence_ordinal": 3,
              "text": "La victoire, longtemps incertaine, fut décidée et gagnée lorsque le maréchal Davout déboucha sur le plateau et déborda l'ennemi, qui, après avoir fait de vains efforts pour le reprendre, battit en retraite.",
              "word_offset_start": 695,
              "word_offset_end": 727,
              "char_offset_start": 4257,
              "char_offset_end": 4463,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p15_s04",
              "sentence_ordinal": 4,
              "text": "Au même moment, le corps du maréchal Ney débouchait par Althof sur la gauche, et poussait devant lui le reste de la colonne prussienne échappée au combat de Deppen.",
              "word_offset_start": 727,
              "word_offset_end": 756,
              "char_offset_start": 4464,
              "char_offset_end": 4628,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p15_s05",
              "sentence_ordinal": 5,
              "text": "Il vint se placer le soir an village de Schmoditten ; et par là l'ennemi se trouva tellement serré entre les corps des maréchaux Ney et Davout, que, craignant de voir son arrière-garde compromise, il résolut, à huit heures du soir, de reprendre le village de Schmodiiten.",
              "word_offset_start": 756,
              "word_offset_end": 803,
              "char_offset_start": 4629,
              "char_offset_end": 4900,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p15_s06",
              "sentence_ordinal": 6,
              "text": "Plusieurs bataillons de grenadiers russes, les seuls qui n'eussent pas donné, se présentèrent à ce village; mais le 6e régiment d'infanterie légère les laissa approcher à bout portant et les mit dans une entière déroute.",
              "word_offset_start": 803,
              "word_offset_end": 838,
              "char_offset_start": 4901,
              "char_offset_end": 5121,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p15_s07",
              "sentence_ordinal": 7,
              "text": "Le lendemain, l'ennemi a été poursuivi jusqu'à la rivière de Frisching.",
              "word_offset_start": 838,
              "word_offset_end": 849,
              "char_offset_start": 5122,
              "char_offset_end": 5193,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p15_s08",
              "sentence_ordinal": 8,
              "text": "Il se retire au delà de la Pregel.",
              "word_offset_start": 849,
              "word_offset_end": 857,
              "char_offset_start": 5194,
              "char_offset_end": 5228,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p15_s09",
              "sentence_ordinal": 9,
              "text": "Il a abandonné sur le champ de bataille 16 pièces de canon et ses blessés.",
              "word_offset_start": 857,
              "word_offset_end": 872,
              "char_offset_start": 5229,
              "char_offset_end": 5303,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p15_s10",
              "sentence_ordinal": 10,
              "text": "Toutes les maisons des villages qu'il a parcourus la nuit en sont remplies.",
              "word_offset_start": 872,
              "word_offset_end": 885,
              "char_offset_start": 5304,
              "char_offset_end": 5379,
              "authorship_note": null,
              "metaphor_instances": []
            }
          ]
        },
        {
          "paragraph_id": "napoleon-bulletin-1807-02-08-eylau_s01_p16",
          "paragraph_ordinal": 16,
          "sentences": [
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p16_s01",
              "sentence_ordinal": 1,
              "text": "Le maréchal Augereau a été blessé d'une balle.",
              "word_offset_start": 885,
              "word_offset_end": 893,
              "char_offset_start": 5381,
              "char_offset_end": 5427,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p16_s02",
              "sentence_ordinal": 2,
              "text": "Les généraux Desjardins, Heudelet, Lochet, ont été blessés.",
              "word_offset_start": 893,
              "word_offset_end": 901,
              "char_offset_start": 5428,
              "char_offset_end": 5487,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p16_s03",
              "sentence_ordinal": 3,
              "text": "Le général Corbineau a été enlevé par un boulet.",
              "word_offset_start": 901,
              "word_offset_end": 910,
              "char_offset_start": 5488,
              "char_offset_end": 5536,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p16_s04",
              "sentence_ordinal": 4,
              "text": "Le colonel Lacué, du 63e, et le colonel Lemarois, du 43e, ont été tués par des boulets.",
              "word_offset_start": 910,
              "word_offset_end": 927,
              "char_offset_start": 5537,
              "char_offset_end": 5624,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p16_s05",
              "sentence_ordinal": 5,
              "text": "Le colonel Bouvières, du 11e régiment de dragons, n'a pas survécu à ses blessures.",
              "word_offset_start": 927,
              "word_offset_end": 941,
              "char_offset_start": 5625,
              "char_offset_end": 5707,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p16_s06",
              "sentence_ordinal": 6,
              "text": "Tous sont morts avec gloire.",
              "word_offset_start": 941,
              "word_offset_end": 946,
              "char_offset_start": 5708,
              "char_offset_end": 5736,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p16_s07",
              "sentence_ordinal": 7,
              "text": "Notre perte se monte exactement à 1,900 morts et 5,700 blessés, parmi lesquels un millier, qui le sont grièvement, seront hors de service.",
              "word_offset_start": 946,
              "word_offset_end": 969,
              "char_offset_start": 5737,
              "char_offset_end": 5875,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p16_s08",
              "sentence_ordinal": 8,
              "text": "Tous les morts ont été enterrés dans la journée du 10.",
              "word_offset_start": 969,
              "word_offset_end": 980,
              "char_offset_start": 5876,
              "char_offset_end": 5930,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p16_s09",
              "sentence_ordinal": 9,
              "text": "On a compté sur le champ de bataille 7,000 Russes.",
              "word_offset_start": 980,
              "word_offset_end": 990,
              "char_offset_start": 5931,
              "char_offset_end": 5981,
              "authorship_note": null,
              "metaphor_instances": []
            }
          ]
        },
        {
          "paragraph_id": "napoleon-bulletin-1807-02-08-eylau_s01_p17",
          "paragraph_ordinal": 17,
          "sentences": [
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p17_s01",
              "sentence_ordinal": 1,
              "text": "Ainsi l'expédition offensive de l'ennemi, qui avait pour but de se porter sur Thorn en débordant la gauche de la Grande Armée, lui a été funeste : 12 à 15,000 prisonniers, autant d'hommes hors de combat, 18 drapeaux, 45 pièces de canon, sont les trophées trop chèrement payés sans doute par le sang de tant de braves.",
              "word_offset_start": 990,
              "word_offset_end": 1047,
              "char_offset_start": 5983,
              "char_offset_end": 6300,
              "authorship_note": null,
              "metaphor_instances": []
            }
          ]
        },
        {
          "paragraph_id": "napoleon-bulletin-1807-02-08-eylau_s01_p18",
          "paragraph_ordinal": 18,
          "sentences": [
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p18_s01",
              "sentence_ordinal": 1,
              "text": "De petites contrariétés de temps, qui auraient paru légères dans toute autre circonstance, ont beaucoup contrarié les combinaisons du général français.",
              "word_offset_start": 1047,
              "word_offset_end": 1068,
              "char_offset_start": 6302,
              "char_offset_end": 6453,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p18_s02",
              "sentence_ordinal": 2,
              "text": "Notre cavalerie et notre artillerie ont fait des merveilles.",
              "word_offset_start": 1068,
              "word_offset_end": 1077,
              "char_offset_start": 6454,
              "char_offset_end": 6514,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p18_s03",
              "sentence_ordinal": 3,
              "text": "La Garde à cheval s'est surpassée- , c'est beaucoup dire.",
              "word_offset_start": 1077,
              "word_offset_end": 1087,
              "char_offset_start": 6515,
              "char_offset_end": 6572,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p18_s04",
              "sentence_ordinal": 4,
              "text": "La Garde à pied a été toute la journée l'arme au bras, sous le feu d'une épouvantable mitraille, sans tirer un coup de fusil ni faire aucun",
              "word_offset_start": 1087,
              "word_offset_end": 1114,
              "char_offset_start": 6573,
              "char_offset_end": 6712,
              "authorship_note": null,
              "metaphor_instances": []
            }
          ]
        },
        {
          "paragraph_id": "napoleon-bulletin-1807-02-08-eylau_s01_p19",
          "paragraph_ordinal": 19,
          "sentences": [
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p19_s01",
              "sentence_ordinal": 1,
              "text": "mouvement; les circonstances n'ont point été telles qu'elle ait dû",
              "word_offset_start": 1114,
              "word_offset_end": 1124,
              "char_offset_start": 6714,
              "char_offset_end": 6780,
              "authorship_note": null,
              "metaphor_instances": []
            }
          ]
        },
        {
          "paragraph_id": "napoleon-bulletin-1807-02-08-eylau_s01_p20",
          "paragraph_ordinal": 20,
          "sentences": [
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p20_s01",
              "sentence_ordinal": 1,
              "text": "donner.",
              "word_offset_start": 1124,
              "word_offset_end": 1125,
              "char_offset_start": 6782,
              "char_offset_end": 6789,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p20_s02",
              "sentence_ordinal": 2,
              "text": "La blessure du maréchal Augereau a été aussi un accident défavorable, en laissant, pendant le plus fort de la mêlée, son corps d'armée sans chef capable de le diriger.",
              "word_offset_start": 1125,
              "word_offset_end": 1154,
              "char_offset_start": 6790,
              "char_offset_end": 6957,
              "authorship_note": null,
              "metaphor_instances": []
            }
          ]
        },
        {
          "paragraph_id": "napoleon-bulletin-1807-02-08-eylau_s01_p21",
          "paragraph_ordinal": 21,
          "sentences": [
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p21_s01",
              "sentence_ordinal": 1,
              "text": "Ce récit est l'idée générale de la bataille.",
              "word_offset_start": 1154,
              "word_offset_end": 1162,
              "char_offset_start": 6959,
              "char_offset_end": 7003,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p21_s02",
              "sentence_ordinal": 2,
              "text": "Il s'est passé des faits qui honorent le soldat français ; l'état-major s'occupe de les recueillir.",
              "word_offset_start": 1162,
              "word_offset_end": 1178,
              "char_offset_start": 7004,
              "char_offset_end": 7103,
              "authorship_note": null,
              "metaphor_instances": []
            }
          ]
        },
        {
          "paragraph_id": "napoleon-bulletin-1807-02-08-eylau_s01_p22",
          "paragraph_ordinal": 22,
          "sentences": [
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p22_s01",
              "sentence_ordinal": 1,
              "text": "La consommation en munitions à canon a été considérable ; elle a été beaucoup moindre en munitions d'infanterie.",
              "word_offset_start": 1178,
              "word_offset_end": 1196,
              "char_offset_start": 7105,
              "char_offset_end": 7217,
              "authorship_note": null,
              "metaphor_instances": []
            }
          ]
        },
        {
          "paragraph_id": "napoleon-bulletin-1807-02-08-eylau_s01_p23",
          "paragraph_ordinal": 23,
          "sentences": [
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p23_s01",
              "sentence_ordinal": 1,
              "text": "L'aigle d'un des bataillons du 18e régiment ne s'est pas retrouvéeelle est probablement tombée entre les mains de l'ennemi.",
              "word_offset_start": 1196,
              "word_offset_end": 1215,
              "char_offset_start": 7219,
              "char_offset_end": 7342,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p23_s02",
              "sentence_ordinal": 2,
              "text": "On ne peut en faire un reproche à ce régiment : c'est, dans la position où il se trouvait, un accident de guerre; toutefois l'Empereur lui en rendra une autre lorsqu'il aura pris un drapeau à l'ennemi.",
              "word_offset_start": 1215,
              "word_offset_end": 1252,
              "char_offset_start": 7343,
              "char_offset_end": 7544,
              "authorship_note": null,
              "metaphor_instances": []
            }
          ]
        },
        {
          "paragraph_id": "napoleon-bulletin-1807-02-08-eylau_s01_p24",
          "paragraph_ordinal": 24,
          "sentences": [
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p24_s01",
              "sentence_ordinal": 1,
              "text": "Cette expédition est terminée, l'ennemi battu et rejeté à cent lieues de la Vistule.",
              "word_offset_start": 1252,
              "word_offset_end": 1266,
              "char_offset_start": 7546,
              "char_offset_end": 7630,
              "authorship_note": null,
              "metaphor_instances": []
            },
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p24_s02",
              "sentence_ordinal": 2,
              "text": "L'armée va reprendre ses cantonnements et rentrer dans ses quartiers d'hiver.",
              "word_offset_start": 1266,
              "word_offset_end": 1277,
              "char_offset_start": 7631,
              "char_offset_end": 7708,
              "authorship_note": null,
              "metaphor_instances": []
            }
          ]
        },
        {
          "paragraph_id": "napoleon-bulletin-1807-02-08-eylau_s01_p25",
          "paragraph_ordinal": 25,
          "sentences": [
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p25_s01",
              "sentence_ordinal": 1,
              "text": "Moniteur du 24 février 1807.",
              "word_offset_start": 1277,
              "word_offset_end": 1282,
              "char_offset_start": 7710,
              "char_offset_end": 7738,
              "authorship_note": null,
              "metaphor_instances": []
            }
          ]
        },
        {
          "paragraph_id": "napoleon-bulletin-1807-02-08-eylau_s01_p26",
          "paragraph_ordinal": 26,
          "sentences": [
            {
              "sentence_id": "napoleon-bulletin-1807-02-08-eylau_s01_p26_s01",
              "sentence_ordinal": 1,
              "text": "(En minute au Dépôt de la guerre.)",
              "word_offset_start": 1282,
              "word_offset_end": 1289,
              "char_offset_start": 7740,
              "char_offset_end": 7774,
              "authorship_note": null,
              "metaphor_instances": []
            }
          ]
        }
      ]
    }
  ],
