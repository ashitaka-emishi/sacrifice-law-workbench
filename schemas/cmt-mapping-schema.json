{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CMT mapping document",
  "type": "object",
  "additionalProperties": true,
  "required": ["version", "case_id", "status", "mappings"],
  "properties": {
    "version": { "type": "string" },
    "case_id": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["draft", "in_review", "reviewed", "accepted"]
    },
    "mappings": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/mapping" }
    }
  },
  "$defs": {
    "mapping": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "mapping_id",
        "case_id",
        "document_id",
        "sentence_id",
        "mipvu_ids",
        "expression",
        "source_domain_primary",
        "target_domain",
        "conceptual_metaphor",
        "entailments",
        "cluster_id",
        "confidence",
        "rival_reading",
        "justification"
      ],
      "properties": {
        "mapping_id": { "type": "string", "minLength": 1 },
        "case_id": { "type": "string", "minLength": 1 },
        "document_id": { "type": "string", "minLength": 1 },
        "sentence_id": { "type": "string", "minLength": 1 },
        "mipvu_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "expression": { "type": "string", "minLength": 1 },
        "evidence_span": { "type": "string" },
        "source_domain_primary": { "type": "string", "minLength": 1 },
        "source_domain_secondary": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "target_domain": { "type": "string", "minLength": 1 },
        "conceptual_metaphor": { "type": "string", "minLength": 1 },
        "entailments": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "cluster_id": { "type": "string", "minLength": 1 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "rival_reading": { "type": "string", "minLength": 1 },
        "justification": { "type": "string", "minLength": 1 },
        "mapping_status": {
          "type": "string",
          "enum": ["provisional", "reviewed", "accepted", "rejected", "exploratory"]
        },
        "rhetorical_salience": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "rhetorical_functions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "ideological_functions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "diachronic_stage": { "type": "string" }
      }
    }
  }
}
