{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Case document manifest",
  "type": "object",
  "additionalProperties": true,
  "required": ["documents"],
  "properties": {
    "status": { "type": "string" },
    "documents": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "document_id",
          "title",
          "date",
          "register",
          "source_url",
          "rights_status",
          "expected_raw_path",
          "analytical_priority"
        ],
        "properties": {
          "document_id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "short_title": { "type": "string" },
          "date": { "type": "string", "minLength": 1 },
          "date_precision": { "type": "string" },
          "register": { "type": "string", "minLength": 1 },
          "authorship": { "type": "string" },
          "authorship_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "source_url": { "type": "string" },
          "source_citation": { "type": "string" },
          "rights_status": { "type": "string", "minLength": 1 },
          "expected_raw_path": { "type": "string", "minLength": 1 },
          "analytical_priority": { "type": "string", "minLength": 1 },
          "risk_flags": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
