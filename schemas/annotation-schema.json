{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Case annotation instance",
  "type": "object",
  "additionalProperties": true,
  "required": ["instance_id", "document_id", "sentence_id", "span_text", "cmt", "koenigsberg", "meta"],
  "anyOf": [
    { "required": ["mipvu_ids"] },
    {
      "properties": {
        "meta": {
          "type": "object",
          "required": ["exploratory_without_mipvu"],
          "properties": {
            "exploratory_without_mipvu": { "const": true }
          }
        }
      }
    }
  ],
  "properties": {
    "instance_id": { "type": "string", "minLength": 1 },
    "case_id": { "type": "string" },
    "document_id": { "type": "string", "minLength": 1 },
    "sentence_id": { "type": "string", "minLength": 1 },
    "span_text": { "type": "string", "minLength": 1 },
    "mipvu_ids": {
      "type": "array",
      "description": "MIPVU lexical-unit IDs that support this interpretive annotation. Each referenced unit should be metaphor-related or uncertain unless meta.exploratory_without_mipvu is true.",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "cmt": {
      "type": "object",
      "additionalProperties": true,
      "required": ["cluster_id"],
      "properties": {
        "cluster_id": { "type": "string", "minLength": 1 },
        "source_domain": { "type": "string" },
        "target_domain": { "type": "string" },
        "entailments": {
          "type": "array",
          "items": { "type": "string" }
        },
        "co_activated_clusters": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "koenigsberg": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "fantasy_type": {},
        "violence_logic": {},
        "obligatory_frame": { "type": "boolean" },
        "sacrificial_economy": { "type": "boolean" },
        "absence_flags": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "gloss_en": {
      "type": "string",
      "description": "Working English rendering of span_text for French-language cases (source-with-glosses policy). Analytical aid only — not a publication translation."
    },
    "gloss_notes": {
      "type": "string",
      "description": "Notes on contested French terms where translation choice affects CMT source-domain mapping (e.g. gloire, sacrifice, patrie, honneur)."
    },
    "meta": {
      "type": "object",
      "additionalProperties": true,
      "required": ["confidence"],
      "properties": {
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "ambiguity_flag": { "type": "boolean" },
        "suppression_flag": { "type": "boolean" },
        "exploratory_without_mipvu": {
          "type": "boolean",
          "description": "Temporary escape hatch for exploratory notes that do not yet have MIPVU backing. These should not support strict aggregate claims."
        }
      }
    }
  }
}
