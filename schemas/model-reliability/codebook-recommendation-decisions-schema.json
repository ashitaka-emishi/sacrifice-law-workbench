{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Human decisions on generated codebook recommendations",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "case_id", "decision_authority", "decisions"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "case_id": { "type": "string", "minLength": 1 },
    "decision_authority": { "const": "human-only" },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["recommendation_id", "disposition", "rationale", "reviewer", "decided_at"],
        "properties": {
          "recommendation_id": { "type": "string", "pattern": "^codebook-rec-[0-9a-f]{12}$" },
          "disposition": { "enum": ["accepted", "rejected", "deferred"] },
          "rationale": { "type": "string", "minLength": 1 },
          "reviewer": { "type": ["string", "null"] },
          "decided_at": { "type": ["string", "null"], "format": "date-time" }
        },
        "allOf": [
          {
            "if": { "properties": { "disposition": { "enum": ["accepted", "rejected"] } } },
            "then": {
              "properties": {
                "reviewer": { "type": "string", "minLength": 1 },
                "decided_at": { "type": "string", "format": "date-time" }
              }
            }
          }
        ]
      }
    }
  }
}
