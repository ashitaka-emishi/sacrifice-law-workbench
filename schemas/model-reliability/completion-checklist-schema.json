{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Model reliability milestone completion checklist",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "case_id",
    "generator",
    "status",
    "run_ids",
    "authority",
    "required_commands",
    "checks",
    "summary"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "case_id": { "type": "string", "minLength": 1 },
    "generator": {
      "const": "scripts/model_reliability/completion_checklist.py"
    },
    "status": { "enum": ["blocked", "complete"] },
    "run_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "consensus_changes_accepted_annotations",
        "decision_authority"
      ],
      "properties": {
        "consensus_changes_accepted_annotations": { "const": false },
        "decision_authority": { "const": "human-only" }
      }
    },
    "required_commands": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["command", "status", "exit_code"],
        "properties": {
          "command": {
            "enum": [
              "npm run status",
              "npm run validate",
              "npm run pipeline",
              "quarto render"
            ]
          },
          "status": { "enum": ["pass", "not-passed"] },
          "exit_code": { "type": ["integer", "null"] }
        }
      }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["check_id", "category", "status", "detail", "evidence"],
        "properties": {
          "check_id": { "type": "string", "minLength": 1 },
          "category": {
            "enum": [
              "artifacts",
              "documentation",
              "protected-paths",
              "repository"
            ]
          },
          "status": { "enum": ["pass", "fail"] },
          "detail": { "type": "string", "minLength": 1 },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "check_count",
        "passed_count",
        "failed_count",
        "failed_check_ids"
      ],
      "properties": {
        "check_count": { "type": "integer", "minimum": 1 },
        "passed_count": { "type": "integer", "minimum": 0 },
        "failed_count": { "type": "integer", "minimum": 0 },
        "failed_check_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
