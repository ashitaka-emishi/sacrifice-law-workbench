{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sacrifice-law-workbench.local/schemas/model-reliability/packet-manifest-schema.json",
  "title": "Deterministic blind packet manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "packet_id",
    "packet_hash",
    "case_id",
    "sample_id",
    "sample_version",
    "source_language",
    "rights_constraints",
    "code_revision",
    "generator",
    "selection_summary",
    "prompts",
    "source_inputs",
    "payloads"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "packet_id": { "$ref": "#/$defs/nonEmptyString" },
    "packet_hash": { "$ref": "#/$defs/sha256" },
    "case_id": { "$ref": "#/$defs/nonEmptyString" },
    "sample_id": { "$ref": "#/$defs/nonEmptyString" },
    "sample_version": { "$ref": "#/$defs/nonEmptyString" },
    "source_language": { "$ref": "#/$defs/languageTag" },
    "rights_constraints": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/nonEmptyString" },
      "uniqueItems": true
    },
    "code_revision": { "$ref": "#/$defs/nonEmptyString" },
    "generator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["script", "version", "script_hash"],
      "properties": {
        "script": { "const": "scripts/model_reliability/generate_packets.py" },
        "version": { "const": "1.0.0" },
        "script_hash": { "$ref": "#/$defs/sha256" }
      }
    },
    "selection_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sentences", "lexical_units", "negative_controls", "ambiguous_items", "claim_relevant_items"],
      "properties": {
        "sentences": { "type": "integer", "minimum": 1 },
        "lexical_units": { "type": "integer", "minimum": 1 },
        "negative_controls": { "type": "integer", "minimum": 1 },
        "ambiguous_items": { "type": "integer", "minimum": 1 },
        "claim_relevant_items": { "type": "integer", "minimum": 1 }
      }
    },
    "prompts": {
      "type": "array",
      "minItems": 3,
      "items": { "$ref": "#/$defs/hashedArtifact" }
    },
    "source_inputs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/hashedArtifact" }
    },
    "payloads": {
      "type": "array",
      "minItems": 3,
      "items": {
        "allOf": [
          { "$ref": "#/$defs/hashedArtifact" },
          {
            "type": "object",
            "required": ["task_layer", "item_count"],
            "properties": {
              "task_layer": { "enum": ["identification", "cmt", "interpretation"] },
              "item_count": { "type": "integer", "minimum": 1 }
            }
          }
        ]
      }
    }
  },
  "$defs": {
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "sha256": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "languageTag": { "type": "string", "pattern": "^[A-Za-z]{2,3}(?:-[A-Za-z0-9]{2,8})*$" },
    "hashedArtifact": {
      "type": "object",
      "required": ["id", "path", "hash"],
      "properties": {
        "id": { "$ref": "#/$defs/nonEmptyString" },
        "path": { "$ref": "#/$defs/nonEmptyString" },
        "hash": { "$ref": "#/$defs/sha256" }
      }
    }
  }
}
