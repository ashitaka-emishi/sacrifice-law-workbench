{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sacrifice-law-workbench.local/schemas/human-reliability/packet-manifest-schema.json",
  "title": "Deterministic blind human packet manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "packet_id", "packet_hash", "case_id", "sample_id",
    "sample_version", "sample_hash", "source_language", "task_layer",
    "codebook_version", "rights_constraints", "generator", "selection_summary",
    "source_inputs", "payloads"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "packet_id": { "$ref": "#/$defs/nonEmptyString" },
    "packet_hash": { "$ref": "#/$defs/sha256" },
    "case_id": { "$ref": "#/$defs/nonEmptyString" },
    "sample_id": { "$ref": "#/$defs/nonEmptyString" },
    "sample_version": { "$ref": "#/$defs/nonEmptyString" },
    "sample_hash": { "$ref": "#/$defs/sha256" },
    "source_language": { "type": "string", "pattern": "^[A-Za-z]{2,3}(?:-[A-Za-z0-9]{2,8})*$" },
    "task_layer": { "enum": ["identification", "cmt", "interpretation"] },
    "codebook_version": { "$ref": "#/$defs/nonEmptyString" },
    "rights_constraints": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": { "$ref": "#/$defs/nonEmptyString" }
    },
    "generator": {
      "type": "object", "additionalProperties": false,
      "required": ["script", "version", "script_hash", "code_revision"],
      "properties": {
        "script": { "const": "scripts/human_reliability/generate_packets.py" },
        "version": { "const": "1.0.0" },
        "script_hash": { "$ref": "#/$defs/sha256" },
        "code_revision": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "selection_summary": {
      "type": "object", "additionalProperties": false,
      "required": ["item_count", "sentence_count", "lexical_unit_count"],
      "properties": {
        "item_count": { "type": "integer", "minimum": 1 },
        "sentence_count": { "type": "integer", "minimum": 1 },
        "lexical_unit_count": { "type": "integer", "minimum": 1 }
      }
    },
    "source_inputs": {
      "type": "array", "minItems": 1,
      "items": { "$ref": "#/$defs/hashedArtifact" }
    },
    "payloads": {
      "type": "array", "minItems": 3, "maxItems": 3,
      "items": {
        "allOf": [
          { "$ref": "#/$defs/hashedArtifact" },
          {
            "type": "object", "required": ["media_type"],
            "properties": { "media_type": { "$ref": "#/$defs/nonEmptyString" } }
          }
        ]
      }
    }
  },
  "$defs": {
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "sha256": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "hashedArtifact": {
      "type": "object",
      "required": ["id", "path", "hash"],
      "properties": {
        "id": { "$ref": "#/$defs/nonEmptyString" },
        "path": { "$ref": "#/$defs/nonEmptyString" },
        "hash": { "$ref": "#/$defs/sha256" }
      }
    }
  }
}
