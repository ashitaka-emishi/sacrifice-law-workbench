{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sacrifice-law-workbench.local/schemas/human-reliability/agreement-results-schema.json",
  "title": "Layered human inter-annotator agreement results",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "case_id", "cohort_id", "cohort_version",
    "source_language", "task_layer", "packet_id", "coder_ids",
    "input_runs", "generator", "scope", "coder_pairs", "field_metrics"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "case_id": { "$ref": "#/$defs/nonEmptyString" },
    "cohort_id": { "$ref": "#/$defs/nonEmptyString" },
    "cohort_version": { "$ref": "#/$defs/nonEmptyString" },
    "source_language": { "$ref": "#/$defs/nonEmptyString" },
    "task_layer": { "enum": ["identification", "cmt", "interpretation"] },
    "packet_id": { "$ref": "#/$defs/nonEmptyString" },
    "coder_ids": {
      "type": "array", "minItems": 2, "uniqueItems": true,
      "items": { "$ref": "#/$defs/nonEmptyString" }
    },
    "input_runs": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "registration_id", "raw_hash", "submission_id", "coder_id"
        ],
        "properties": {
          "registration_id": { "$ref": "#/$defs/nonEmptyString" },
          "raw_hash": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$"
          },
          "submission_id": { "$ref": "#/$defs/nonEmptyString" },
          "coder_id": { "$ref": "#/$defs/nonEmptyString" }
        }
      }
    },
    "generator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["script", "version", "script_hash", "code_revision"],
      "properties": {
        "script": { "const": "scripts/human_reliability/compute_agreement.py" },
        "version": { "const": "1.0.0" },
        "script_hash": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "code_revision": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pooled", "pair_count", "item_count", "lexical_unit_count",
        "out_of_scope_counts"
      ],
      "properties": {
        "pooled": { "const": false },
        "pair_count": { "type": "integer", "minimum": 1 },
        "item_count": { "type": "integer", "minimum": 1 },
        "lexical_unit_count": { "type": "integer", "minimum": 1 },
        "out_of_scope_counts": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "coder_pairs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["left_coder_id", "right_coder_id", "field_metrics"],
        "properties": {
          "left_coder_id": { "$ref": "#/$defs/nonEmptyString" },
          "right_coder_id": { "$ref": "#/$defs/nonEmptyString" },
          "field_metrics": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/$defs/fieldMetric" }
          }
        }
      }
    },
    "field_metrics": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/fieldMetric" }
    }
  },
  "$defs": {
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "statistic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "value", "undefined_reason"],
      "properties": {
        "status": { "enum": ["defined", "undefined", "not_applicable"] },
        "value": { "type": ["number", "null"], "minimum": -1, "maximum": 1 },
        "undefined_reason": { "type": ["string", "null"] }
      }
    },
    "fieldMetric": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_layer", "field", "metric_family", "value_type",
        "comparable_count", "missing_count", "exact_match_count",
        "sample_assessment", "observed_agreement", "cohens_kappa",
        "positive_agreement", "negative_agreement", "mean_jaccard",
        "mean_absolute_difference", "mean_ordinal_distance", "notes"
      ],
      "properties": {
        "task_layer": { "enum": ["identification", "cmt", "interpretation"] },
        "field": { "$ref": "#/$defs/nonEmptyString" },
        "metric_family": {
          "enum": [
            "nominal", "binary_identification", "set_overlap",
            "numeric_distance", "ordinal_distance", "qualitative_only"
          ]
        },
        "value_type": {
          "enum": ["category", "binary", "set", "number", "ordinal", "text"]
        },
        "comparable_count": { "type": "integer", "minimum": 0 },
        "missing_count": { "type": "integer", "minimum": 0 },
        "exact_match_count": { "type": "integer", "minimum": 0 },
        "sample_assessment": { "enum": ["adequate", "sparse", "unavailable"] },
        "observed_agreement": { "$ref": "#/$defs/statistic" },
        "cohens_kappa": { "$ref": "#/$defs/statistic" },
        "positive_agreement": { "$ref": "#/$defs/statistic" },
        "negative_agreement": { "$ref": "#/$defs/statistic" },
        "mean_jaccard": { "$ref": "#/$defs/statistic" },
        "mean_absolute_difference": { "$ref": "#/$defs/statistic" },
        "mean_ordinal_distance": { "$ref": "#/$defs/statistic" },
        "notes": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        }
      }
    }
  }
}
