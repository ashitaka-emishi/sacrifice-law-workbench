{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sacrifice-law-workbench.local/schemas/human-reliability/adjudication-register-schema.json",
  "title": "Immutable human adjudication submission register",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "case_id", "submissions"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "case_id": { "type": "string", "minLength": 1 },
    "submissions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "registration_id", "registered_at", "cohort_id", "cohort_version",
          "adjudication_submission_id", "adjudicator_id", "queue_sha256",
          "raw_hash", "status", "validation_report"
        ],
        "properties": {
          "registration_id": { "type": "string", "pattern": "^adjudication-registration-[0-9a-f]{16}$" },
          "registered_at": { "type": "string", "format": "date-time" },
          "cohort_id": { "type": ["string", "null"] },
          "cohort_version": { "type": ["string", "null"] },
          "adjudication_submission_id": { "type": ["string", "null"] },
          "adjudicator_id": { "type": ["string", "null"] },
          "queue_sha256": {
            "type": ["string", "null"],
            "pattern": "^sha256:[0-9a-f]{64}$"
          },
          "raw_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
          "status": { "enum": ["valid", "invalid"] },
          "validation_report": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
