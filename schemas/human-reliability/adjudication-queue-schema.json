{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sacrifice-law-workbench.local/schemas/human-reliability/adjudication-queue-schema.json",
  "title": "Independent human adjudication queue",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "case_id", "cohort_id", "cohort_version",
    "source_language", "task_layer", "packet_id", "generator",
    "input_artifacts", "queue_policy", "summary", "entries"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "case_id": { "$ref": "#/$defs/nonEmptyString" },
    "cohort_id": { "$ref": "#/$defs/nonEmptyString" },
    "cohort_version": { "$ref": "#/$defs/nonEmptyString" },
    "source_language": { "$ref": "#/$defs/languageTag" },
    "task_layer": { "enum": ["identification", "cmt", "interpretation"] },
    "packet_id": { "$ref": "#/$defs/nonEmptyString" },
    "generator": { "$ref": "#/$defs/generator" },
    "input_artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "disagreement_log", "packet_manifest", "packet_payload",
        "claim_traces", "model_agreement"
      ],
      "properties": {
        "disagreement_log": { "$ref": "#/$defs/artifact" },
        "packet_manifest": { "$ref": "#/$defs/artifact" },
        "packet_payload": { "$ref": "#/$defs/artifact" },
        "claim_traces": { "$ref": "#/$defs/artifact" },
        "model_agreement": { "$ref": "#/$defs/artifact" }
      }
    },
    "queue_policy": { "$ref": "#/$defs/nonEmptyString" },
    "summary": { "$ref": "#/$defs/summary" },
    "entries": {
      "type": "array",
      "items": { "$ref": "#/$defs/entry" }
    }
  },
  "$defs": {
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "languageTag": {
      "type": "string",
      "pattern": "^[A-Za-z]{2,3}(?:-[A-Za-z0-9]{2,8})*$"
    },
    "sha256": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "stringArray": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/nonEmptyString" }
    },
    "generator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["script", "version", "script_hash", "code_revision"],
      "properties": {
        "script": { "const": "scripts/human_reliability/generate_adjudication_queue.py" },
        "version": { "const": "1.0.0" },
        "script_hash": { "$ref": "#/$defs/sha256" },
        "code_revision": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "source", "sha256"],
      "properties": {
        "status": { "enum": ["available", "unavailable", "in_memory"] },
        "source": { "type": ["string", "null"] },
        "sha256": {
          "type": ["string", "null"],
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      }
    },
    "countMap": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "queue_count", "high_priority_count", "claim_linked_count",
        "major_claim_impact_count", "model_summary_available_count", "by_priority"
      ],
      "properties": {
        "queue_count": { "type": "integer", "minimum": 0 },
        "high_priority_count": { "type": "integer", "minimum": 0 },
        "claim_linked_count": { "type": "integer", "minimum": 0 },
        "major_claim_impact_count": { "type": "integer", "minimum": 0 },
        "model_summary_available_count": { "type": "integer", "minimum": 0 },
        "by_priority": { "$ref": "#/$defs/countMap" }
      }
    },
    "coderValue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["coder_id", "value"],
      "properties": {
        "coder_id": { "$ref": "#/$defs/nonEmptyString" },
        "value": {}
      }
    },
    "referenceSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "value", "authority"],
      "properties": {
        "status": { "enum": ["available", "unavailable", "not_comparable"] },
        "value": {},
        "authority": {
          "type": ["string", "null"],
          "enum": [null, "accepted", "reviewed", "reviewable_reference"]
        }
      }
    },
    "modelMetricSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "comparison_family", "left_id", "right_id", "field",
        "comparable_count", "exact_match_count", "metric_name",
        "metric_status", "metric_value"
      ],
      "properties": {
        "comparison_family": { "enum": ["model_vs_model", "model_vs_reference"] },
        "left_id": { "$ref": "#/$defs/nonEmptyString" },
        "right_id": { "$ref": "#/$defs/nonEmptyString" },
        "field": { "$ref": "#/$defs/nonEmptyString" },
        "comparable_count": { "type": "integer", "minimum": 0 },
        "exact_match_count": { "type": "integer", "minimum": 0 },
        "metric_name": { "$ref": "#/$defs/nonEmptyString" },
        "metric_status": { "enum": ["defined", "undefined"] },
        "metric_value": { "type": ["number", "null"] }
      }
    },
    "modelSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status", "source", "run_ids", "matching_summary_count",
        "summaries", "note"
      ],
      "properties": {
        "status": { "enum": ["available", "unavailable", "no_matching_summary"] },
        "source": { "type": ["string", "null"] },
        "run_ids": { "$ref": "#/$defs/stringArray" },
        "matching_summary_count": { "type": "integer", "minimum": 0 },
        "summaries": {
          "type": "array",
          "items": { "$ref": "#/$defs/modelMetricSummary" }
        },
        "note": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_id", "claim_text", "claim_status", "support_dimension",
        "match_reasons"
      ],
      "properties": {
        "claim_id": { "$ref": "#/$defs/nonEmptyString" },
        "claim_text": { "type": "string" },
        "claim_status": { "type": "string" },
        "support_dimension": { "type": "string" },
        "match_reasons": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["unit_id", "sentence_id", "reference_id"] }
        }
      }
    },
    "sourceLanguageRisk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "reasons"],
      "properties": {
        "level": { "enum": ["low", "material", "high"] },
        "reasons": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/nonEmptyString" }
        }
      }
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "queue_id", "queue_rank", "disagreement_id", "source_pattern_id",
        "case_id", "cohort_id", "cohort_version", "source_language", "task_layer",
        "document_id", "sentence_id", "item_id", "reference_id", "unit_id",
        "field", "category", "field_category", "agreement_pattern", "source_text",
        "focal_text", "context_scope", "rights_constraints", "storage_policy",
        "coder_values", "reference_summary", "model_summary", "claim_impact",
        "major_claim_impact", "affected_claims", "affected_claim_dimensions",
        "source_language_risk", "possible_codebook_ambiguity", "upstream_priority",
        "priority", "priority_score", "priority_reasons", "review_question",
        "review_status", "decision_authority", "adjudication_note"
      ],
      "properties": {
        "queue_id": { "type": "string", "pattern": "^human-queue-[0-9a-f]{16}$" },
        "queue_rank": { "type": "integer", "minimum": 1 },
        "disagreement_id": {
          "type": "string",
          "pattern": "^human-disagreement-[0-9a-f]{16}$"
        },
        "source_pattern_id": { "$ref": "#/$defs/nonEmptyString" },
        "case_id": { "$ref": "#/$defs/nonEmptyString" },
        "cohort_id": { "$ref": "#/$defs/nonEmptyString" },
        "cohort_version": { "$ref": "#/$defs/nonEmptyString" },
        "source_language": { "$ref": "#/$defs/languageTag" },
        "task_layer": { "enum": ["identification", "cmt", "interpretation"] },
        "document_id": { "$ref": "#/$defs/nonEmptyString" },
        "sentence_id": { "type": ["string", "null"] },
        "item_id": { "$ref": "#/$defs/nonEmptyString" },
        "reference_id": { "$ref": "#/$defs/nonEmptyString" },
        "unit_id": { "type": ["string", "null"] },
        "field": { "$ref": "#/$defs/nonEmptyString" },
        "category": { "$ref": "#/$defs/nonEmptyString" },
        "field_category": { "$ref": "#/$defs/nonEmptyString" },
        "agreement_pattern": { "$ref": "#/$defs/nonEmptyString" },
        "source_text": { "$ref": "#/$defs/nonEmptyString" },
        "focal_text": { "type": "string" },
        "context_scope": { "$ref": "#/$defs/nonEmptyString" },
        "rights_constraints": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "storage_policy": { "enum": ["repository_allowed", "local_only"] },
        "coder_values": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/coderValue" }
        },
        "reference_summary": { "$ref": "#/$defs/referenceSummary" },
        "model_summary": { "$ref": "#/$defs/modelSummary" },
        "claim_impact": { "enum": ["ordinary", "moderate", "high"] },
        "major_claim_impact": { "type": "boolean" },
        "affected_claims": {
          "type": "array",
          "items": { "$ref": "#/$defs/claim" }
        },
        "affected_claim_dimensions": { "$ref": "#/$defs/stringArray" },
        "source_language_risk": { "$ref": "#/$defs/sourceLanguageRisk" },
        "possible_codebook_ambiguity": { "type": "boolean" },
        "upstream_priority": { "enum": ["low", "medium", "high"] },
        "priority": { "enum": ["low", "medium", "high"] },
        "priority_score": { "type": "integer", "minimum": 0 },
        "priority_reasons": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "review_question": { "$ref": "#/$defs/nonEmptyString" },
        "review_status": { "const": "pending-independent-adjudication" },
        "decision_authority": { "const": "authorized-human-adjudicator" },
        "adjudication_note": { "$ref": "#/$defs/nonEmptyString" }
      },
      "not": {
        "anyOf": [
          { "required": ["adjudication_decision"] },
          { "required": ["accepted_value"] },
          { "required": ["reference_update"] }
        ]
      }
    }
  }
}
