{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sacrifice-law-workbench.local/schemas/human-reliability/ingestion-report-schema.json",
  "title": "Human coder submission ingestion report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "registration_id", "registered_at", "case_id",
    "cohort_id", "cohort_version", "submission_id", "coder_id",
    "source_format", "raw_hash", "status", "errors", "row_results",
    "raw_rows", "cohort_ingestion_state"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "registration_id": { "type": "string", "minLength": 1 },
    "registered_at": { "type": "string", "format": "date-time" },
    "case_id": { "type": "string", "minLength": 1 },
    "cohort_id": { "type": ["string", "null"] },
    "cohort_version": { "type": ["string", "null"] },
    "submission_id": { "type": ["string", "null"] },
    "coder_id": { "type": ["string", "null"] },
    "source_format": { "enum": ["json", "csv"] },
    "raw_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "status": { "enum": ["valid", "invalid"] },
    "errors": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "row_results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["index", "item_id", "status", "errors", "raw_row"],
        "properties": {
          "index": { "type": "integer", "minimum": 0 },
          "item_id": { "type": ["string", "null"] },
          "status": { "enum": ["valid", "invalid"] },
          "errors": { "type": "array", "items": { "type": "string" } },
          "raw_row": {}
        }
      }
    },
    "raw_rows": { "type": "array", "items": { "type": "object" } },
    "cohort_ingestion_state": {
      "enum": ["absent", "partial", "invalid", "complete"]
    }
  }
}
